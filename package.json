{
  "name": "opencode-model-quota",
  "version": "0.1.0",
  "description": "OpenCode TUI plugin for checking model and subscription quota (OpenCode Go, GitHub Copilot).",
  "type": "module",
  "author": "GY <dev.youngkwok718@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/whosydd/opencode-model-usage",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/whosydd/opencode-model-usage.git"
  },
  "keywords": [
    "opencode",
    "tui",
    "plugin",
    "quota",
    "github-copilot",
    "ai"
  ],
  "main": "./dist/tui.js",
  "types": "./dist/tui.d.ts",
  "files": [
    "dist",
    "README.md",
    "README.zh.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "import": "./dist/tui.js",
      "types": "./dist/tui.d.ts"
    },
    "./tui": {
      "import": "./dist/tui.js",
      "types": "./dist/tui.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/tui.ts --format esm --dts --out-dir dist --clean --external @opentui/solid",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm run typecheck"
  },
  "engines": {
    "node": ">=18",
    "opencode": ">=1.14.0"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.14.0"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.14.22",
    "@types/node": "^24.9.1",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3"
  }
}
